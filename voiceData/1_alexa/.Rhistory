library(coefplot)
library(ggplot2)
library(gridExtra)
library(lattice)
library(reshape2)
library(GGally)
attach(tips) #this dataset is part of the reshape2 package. Load package to get access to the data.
View(tips) #let's take a look at the dataset
str(tips)
hist(tip) #let's examine the distribution of tips
hist(total_bill)
summary(total_bill)
hist(tip)
plot(tip)
plot(size,tip)
summary(size)
summary(as.factor(size))
clas(size)
class(size)
str(size)
plot(as.factor(size),tip)
plot(sex,tip) #tips by sex (data type = factor)
plot(day,tip) #tips by day (data type = factor)
t.test(tip~size)
t.test(tip~sex)
hist(tip)
table(sex,size)
hist(log(tip))
hist(sqrt(tip))
t.test(log(tip)~sex)
plot(tip,sex)
plot(sex,tip)
plot(size,tip,main="Party Size on Tips",xlab="Party Size",ylab="Tips (in $)",cex.lab=1.8)
par(mar=c(5,5,5,5))#
?plot
plot(size,tip,main="Party Size on Tips",xlab="Party Size",ylab="Tips (in $)",cex.lab=1.8)
abline(v=mean(size)) #add a vertical line based on mean(size)
abline(h=mean(tip)) #add a horizontal line based on mean(tip)
mean(tip)
?lm
mod <- lm(tip~size) #first, create an object of the lm() function
summary(mod) #let's take a look at the summary of this linear model
abline(mod)
?abline
abline(mod,col="red",lwd=5) #finally, use this object in the plot function
abline(mod,col="blue",lwd=15) #finally, use this object in the plot function
histogram(tip)
xyplot(tip~size) #simple bivariate plot
str(time)
#The power of the lattice package is within conditioning plots
#Here are some examples:
xyplot(tip~size|time)
str(day)
xyplot(tip~size|time*day)
bwplot(tip~day|sex)
bwplot(tip~sex|day)
xyplot(tip~size|day*time,
layout=c(8,1), #adjust layout if you want the panels to be horizontally aligned
panel=function(x,y,...){
panel.xyplot(x,y,...)
panel.loess(x,y,col="black",lwd=2,lty=2)
mod <- lm(y~x)
panel.abline(mod,lwd=2,col="red")
})
str(time)
test <- relevel(time,ref="Lunch")
str(test)
#BASIC plotting
qplot(tip) #produces a histogram
qplot(tip,geom="density") #equivalent
qplot(y=tip,x=size) #produces a bivariate scatterplot
#OVERLAY by factor variables
qplot(tip,fill=sex)
qplot(tip,geom="density", color=sex) #you can also use a density function as an overlay
qplot(tip,geom="density", color=time)
library(gridExtra)
p1 <- qplot(y=tip,x=size,geom=c("smooth"),method="lm")
p2 <- qplot(y=tip,x=size,geom=c("smooth"),method="lm",color=sex)
p3 <- qplot(y=tip,x=size,geom=c("smooth"),method="lm",color=day)
p1
grid.arrange(p1,p2,p3,nrow=1,ncol=3)
#The GGally package is a powerful helper package for ggplot
#Note: the "::" operator prevents the masking issue discussed yesterday
#Thus, the package will NOT be attached to R's search path (check search())
GGally::ggpairs(tips[,1:3])
GGally::ggpairs(tips)
#T-TEST
#Key question: differences in tipping between males and females?
aggregate(tip~sex,data=tips, mean)
var.test(tip~sex)#are variances equal?
t.test(tip~sex, var.equal=F)
?t.test
t.test(tip~sex, var.equal=T)
#ANOVA
mod <- aov(tip~day)
#overall model result
summary(mod)
str(day)
#comparisons
model.tables(mod,"means")
TukeyHSD(mod)
