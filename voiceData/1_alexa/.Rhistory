shapiro.test(tip)
hist(tip)
logtip <- log(tip)
hist(logtip)
logmod <- aov(logtip~day)
summary(logmod)
summary(mod)
TukeyHSD(logmod)
?aov
summary.lm(mod)
str(day)
#MODEL BUILDING
#FIRST, build some models by hand
#intercept only model and four additional models with increasing model complexity
null <- lm(tip~1) #intercept-only or null model
summary(null)
mean(tip)
mod1 <- lm(tip~size)
summary(mod1)
mod2 <- lm(tip~sex+day)
summary(mod2)
mod4 <- lm(tip~sex+day+time+size)
mod1 <- lm(tip~size)
mod2 <- lm(tip~sex+day)
mod3 <- lm(tip~sex+day+time)
mod4 <- lm(tip~sex+day+time+size)
mod5 <- lm(tip~size+smoker+time)
summary(mod1)
summary(mod2)
summary(mod3)
summary(mod4)
summary(mod5)
#SECOND, make a first assessment of the models by using the coefplot() function
library(coefplot)
coefplot(mod1)
coefplot(mod2)
mod1,mod3,mod4
mod1 <- lm(tip~size)
#use multiplot() to compare more models in parallel
multiplot(mod1,mod3,mod4)
#use multiplot() to compare more models in parallel
multiplot(mod1,mod4)
anova(mod1,mod4)
#Finally, a nice package to help with model selection
#Stepwise procedures in the "leaps" package to find best fitting model
library(leaps)
?step
full.lm <-lm(tip~size+smoker+time,data=tips)
summary(full.lm)
full.step.both <- step(full.lm, direction='both') # Use stepwise search, both direction, starting at full model
print(summary(full.step.both)) #final model details
lm(mpg~hp)
